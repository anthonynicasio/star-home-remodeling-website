---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/Section.astro';
import CtaBand from '../components/CtaBand.astro';
import { siteConfig } from '../lib/site-config';
---

<Layout
  title={`About Us | ${siteConfig.name}`}
  description="Family-run home remodeling contractor serving Fairfax, Virginia and the greater DMV since    learn our story."
>
  <Header slot="header" />
  <Footer slot="footer" />

  <Section>
    <h1 class="text-display text-3xl font-bold sm:text-4xl">Built on trust, not volume</h1>
    <div class="prose-star mt-6 max-w-3xl space-y-4 text-base">
      <p>
        Star Home Remodeling is a family-run contractor based in Fairfax, Virginia. We focus on the
        projects that protect and improve your home    roofing, siding, windows, doors, gutters, and
        thoughtful interior updates.
      </p>
      <p>
        We are not a national call center. When you work with us, you get local crews who know
        Mid-Atlantic homes and weather. We show up when we say we will, explain your options in
        plain language, and stand behind our work.
      </p>
      <p class="text-sm text-stone-400">
        // TODO: confirm years in business and team details with client    do not invent stats
      </p>
    </div>
  </Section>

  <Section variant="stone">
    <h2 class="text-display text-2xl font-bold">Why homeowners choose Star</h2>
    <ul class="mt-6 grid gap-4 sm:grid-cols-2">
      <li class="rounded-[var(--radius-default)] bg-paper p-5 shadow-[var(--shadow-card)]">
        <strong class="text-brand-900">Local focus</strong>
        <p class="mt-1 text-sm text-stone-400">Fairfax and the DMV    not a distant franchise.</p>
      </li>
      <li class="rounded-[var(--radius-default)] bg-paper p-5 shadow-[var(--shadow-card)]">
        <strong class="text-brand-900">Honest estimates</strong>
        <p class="mt-1 text-sm text-stone-400">Free inspections with clear, written proposals.</p>
      </li>
      <li class="rounded-[var(--radius-default)] bg-paper p-5 shadow-[var(--shadow-card)]">
        <strong class="text-brand-900">Quality materials</strong>
        <p class="mt-1 text-sm text-stone-400">Manufacturer-backed products installed correctly.</p>
      </li>
      <li class="rounded-[var(--radius-default)] bg-paper p-5 shadow-[var(--shadow-card)]">
        <strong class="text-brand-900">BBB accredited</strong>
        <p class="mt-1 text-sm text-stone-400">A track record you can verify.</p>
      </li>
    </ul>
  </Section>

  <CtaBand />
</Layout>
