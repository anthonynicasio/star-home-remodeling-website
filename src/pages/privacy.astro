---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/Section.astro';
import { siteConfig } from '../lib/site-config';

const effectiveDate = 'January 2025';
---

<Layout
  title={`Privacy Policy | ${siteConfig.name}`}
  description="How Star Home Remodeling collects, uses, and protects the information you share when requesting an estimate or contacting us."
>
  <Header slot="header" />
  <Footer slot="footer" />

  <Section>
    <div class="mx-auto max-w-3xl">
      <h1 class="text-display text-3xl font-bold sm:text-4xl">Privacy Policy</h1>
      <p class="prose-star mt-3 text-sm">Last updated: {effectiveDate}</p>

      <div class="prose-star mt-8 space-y-6 text-base">
        <p>
          This Privacy Policy explains how {siteConfig.name} ("we," "us," or "our") collects and uses
          information when you visit our website or request an estimate. We value your privacy and
          only collect what we need to respond to your request.
        </p>

        <div>
          <h2 class="text-display text-xl font-bold text-brand-900">Information we collect</h2>
          <p class="mt-2">
            When you submit a quote or contact form, we collect the details you provide — such as your
            name, phone number, email address, project ZIP code, and any project details you share. We
            may also collect basic, non-identifying analytics about how visitors use our site.
          </p>
        </div>

        <div>
          <h2 class="text-display text-xl font-bold text-brand-900">How we use your information</h2>
          <p class="mt-2">
            We use your information to respond to your request, prepare your estimate, schedule work,
            and communicate with you about your project. We do not sell your personal information.
          </p>
        </div>

        <div>
          <h2 class="text-display text-xl font-bold text-brand-900">How we protect it</h2>
          <p class="mt-2">
            We take reasonable measures to safeguard the information you share with us and limit access
            to those who need it to serve you.
          </p>
        </div>

        <div>
          <h2 class="text-display text-xl font-bold text-brand-900">Contact us</h2>
          <p class="mt-2">
            Questions about this policy or your information? Reach us at
            <a href={`mailto:${siteConfig.email}`} class="font-semibold text-brand-700 hover:text-accent">{siteConfig.email}</a>
            or
            <a href={`tel:${siteConfig.phone.primaryTel}`} class="font-semibold text-brand-700 hover:text-accent">{siteConfig.phone.primary}</a>.
          </p>
        </div>
      </div>
    </div>
  </Section>
</Layout>
