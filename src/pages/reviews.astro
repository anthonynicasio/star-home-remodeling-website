---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/Section.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import CtaBand from '../components/CtaBand.astro';
import StarRating from '../components/StarRating.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../lib/site-config';

const allReviews = await getCollection('reviews');
---

<Layout
  title={`Reviews | ${siteConfig.name}`}
  description="Read what Fairfax and DMV homeowners say about Star Home Remodeling."
>
  <Header slot="header" />
  <Footer slot="footer" />

  <Section>
    {allReviews.length > 0 && (
      <div class="flex items-center gap-2">
        <StarRating size="h-5 w-5" />
        <span class="text-sm font-semibold text-brand-900">5.0 · Verified Google reviews</span>
      </div>
    )}
    <h1 class="text-display mt-3 text-3xl font-bold sm:text-4xl">Homeowner reviews</h1>
    <p class="prose-star mt-4 max-w-2xl">
      Real feedback from neighbors across the DMV. Recently worked with us? We'd love for you to
      share your experience.
    </p>

    {
      allReviews.length > 0 ? (
        <div class="mt-12">
          <TestimonialCarousel
            reviews={allReviews.map((r) => ({
              quote: r.data.quote,
              author: r.data.author,
              location: r.data.location,
            }))}
          />
        </div>
      ) : (
        <p class="mt-10 text-stone-400">Customer testimonials coming soon.</p>
      )
    }

    <div class="mt-12">
      <a href="/contact" class="btn btn-secondary">Share your experience</a>
    </div>
  </Section>

  <CtaBand />
</Layout>
