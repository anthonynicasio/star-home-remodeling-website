---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Section from '../../components/Section.astro';
import ServicesGrid from '../../components/ServicesGrid.astro';
import CtaBand from '../../components/CtaBand.astro';
import { siteConfig } from '../../lib/site-config';
---

<Layout
  title={`Our Services | Roofing, Siding & Windows | ${siteConfig.name}`}
  description="Roofing, siding, windows, doors, gutters, and exterior remodeling for homeowners across Fairfax and the DMV. Free estimates from a local, family-run team."
>
  <Header slot="header" />
  <Footer slot="footer" />

  <Section>
    <div class="max-w-2xl">
      <p class="eyebrow">Our services</p>
      <h1 class="text-display mt-3 text-3xl font-bold sm:text-4xl">
        Exterior remodeling for every part of your home
      </h1>
      <p class="prose-star mt-4">
        One trusted local team for the upgrades that protect your home and lift its curb appeal —
        across Northern Virginia, Washington, DC, and the Maryland suburbs.
      </p>
    </div>

    <div class="mt-12">
      <ServicesGrid />
    </div>
  </Section>

  <CtaBand />
</Layout>
