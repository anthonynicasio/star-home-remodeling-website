---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  class?: string;
  showWordmark?: boolean;
  variant?: 'default' | 'inverse';
}

const { class: className = '', showWordmark = true, variant = 'default' } = Astro.props;

const logoModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/brand/logo.png',
  { eager: true }
);
const logoSrc = Object.values(logoModules)[0]?.default as ImageMetadata | undefined;

const wordmarkClass =
  variant === 'inverse'
    ? 'text-display text-xl font-bold text-paper'
    : 'text-display text-lg font-bold leading-none text-brand-900';
const subClass =
  variant === 'inverse'
    ? 'block text-xs font-medium tracking-wide text-brand-300'
    : 'block text-xs font-medium tracking-wide text-brand-700';
---

<a
  href="/"
  class:list={['group flex items-center gap-2 no-underline', className]}
  aria-label="Star Home Remodeling home"
>
  {
    logoSrc ? (
      <Image
        src={logoSrc}
        alt="Star Home Remodeling"
        class="h-10 w-auto max-w-[220px] object-contain object-left"
        widths={[120, 180, 240]}
        sizes="(max-width: 768px) 140px, 220px"
        loading="eager"
      />
    ) : (
      <>
        <span
          class="flex h-9 w-9 items-center justify-center rounded-[var(--radius-default)] bg-brand-700 text-gold"
          aria-hidden="true"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2l2.4 7.4H22l-6 4.6 2.3 7-6.3-4.6L5.7 21l2.3-7-6-4.6h7.6L12 2z" />
          </svg>
        </span>
        {showWordmark && (
          <span class={wordmarkClass}>
            STAR{' '}
            {variant === 'inverse' ? (
              <span class="font-normal">Home Remodeling</span>
            ) : (
              <span class={subClass}>Home Remodeling</span>
            )}
          </span>
        )}
      </>
    )
  }
</a>
