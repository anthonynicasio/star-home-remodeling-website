---
interface Step {
  title: string;
  description: string;
}

interface Props {
  title?: string;
  steps: Step[];
}

const { title = 'How it works', steps } = Astro.props;
const cols = steps.length === 4 ? 'lg:grid-cols-4' : 'lg:grid-cols-5';
---

<div>
  {title && <h2 class="text-display text-center text-2xl font-bold sm:text-3xl">{title}</h2>}
  <ol class:list={['grid gap-8 sm:grid-cols-2', cols, title && 'mt-12']}>
    {steps.map((step, index) => (
      <li class="relative">
        <span
          class="text-display flex h-12 w-12 items-center justify-center rounded-full bg-brand-900 text-lg font-bold text-gold ring-4 ring-brand-50"
          aria-hidden="true"
        >
          {index + 1}
        </span>
        <h3 class="text-display mt-5 text-lg font-semibold">{step.title}</h3>
        <p class="prose-star mt-2 text-sm">{step.description}</p>
      </li>
    ))}
  </ol>
</div>
