---
import { Icon } from 'astro-icon/components';

interface Step {
  title: string;
  description: string;
}

interface Props {
  title?: string;
  steps: Step[];
}

const { title = 'How it works', steps } = Astro.props;
---

<div>
  <h2 class="text-display text-center text-2xl font-bold sm:text-3xl">{title}</h2>
  <ol class="mt-12 grid gap-8 md:grid-cols-2 lg:grid-cols-5">
    {steps.map((step, index) => (
      <li class="relative">
        <span
          class="text-display flex h-10 w-10 items-center justify-center rounded-full bg-brand-700 text-lg font-bold text-paper"
          aria-hidden="true"
        >
          {index + 1}
        </span>
        <h3 class="text-display mt-4 text-lg font-semibold">{step.title}</h3>
        <p class="prose-star mt-2 text-sm">{step.description}</p>
      </li>
    ))}
  </ol>
</div>
