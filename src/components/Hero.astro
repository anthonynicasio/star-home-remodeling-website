---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { Icon } from 'astro-icon/components';
import { siteConfig } from '../lib/site-config';
import HeroQuoteForm from './islands/HeroQuoteForm';

interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
  bullets: string[];
  image: ImageMetadata;
  imageAlt: string;
}

const { eyebrow, title, subtitle, bullets, image, imageAlt } = Astro.props;
---

<section class="relative overflow-hidden bg-brand-900">
  <Image
    src={image}
    alt={imageAlt}
    class="absolute inset-0 h-full w-full object-cover"
    loading="eager"
    fetchpriority="high"
    widths={[640, 1024, 1920]}
    sizes="100vw"
  />
  <div class="absolute inset-0 bg-gradient-to-br from-brand-900/90 via-brand-900/72 to-brand-900/52"></div>

  <div class="relative mx-auto grid max-w-6xl gap-10 px-4 py-16 sm:px-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:gap-12 lg:py-24 lg:px-8">
    <div>
      <p class="inline-flex items-center gap-2 rounded-full border border-paper/15 bg-paper/5 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-gold backdrop-blur-sm">
        <span class="h-1.5 w-1.5 rounded-full bg-gold"></span>
        {eyebrow}
      </p>
      <h1 class="text-display mt-5 max-w-xl text-balance text-3xl font-bold text-paper sm:text-4xl lg:text-5xl">
        {title}
      </h1>
      <p class="mt-5 max-w-xl text-base text-brand-50/85 sm:text-lg">{subtitle}</p>

      <ul class="mt-7 grid max-w-xl gap-x-6 gap-y-3 sm:grid-cols-2">
        {bullets.map((bullet) => (
          <li class="flex items-start gap-2.5 text-sm font-medium text-paper">
            <Icon name="lucide:check" class="mt-0.5 h-5 w-5 shrink-0 text-gold" aria-hidden="true" />
            <span>{bullet}</span>
          </li>
        ))}
      </ul>

      <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a href="#quote-form" class="btn btn-primary">Get a Free Quote</a>
        <a
          href="/services"
          class="btn btn-secondary border-paper/30 text-paper hover:bg-paper hover:text-brand-900"
        >
          View Our Services
        </a>
      </div>

      <p class="mt-6 text-sm text-brand-50/80">
        Prefer to talk? Call
        <a href={`tel:${siteConfig.phone.primaryTel}`} class="font-semibold text-gold hover:underline">
          {siteConfig.phone.primary}
        </a>
      </p>
    </div>

    <div id="quote-form" class="scroll-mt-24">
      <HeroQuoteForm client:load />
    </div>
  </div>
</section>
