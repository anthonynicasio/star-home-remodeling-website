---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { Icon } from 'astro-icon/components';
import { siteConfig } from '../lib/site-config';

interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
  bullets: string[];
  image: ImageMetadata;
  imageAlt: string;
}

const { eyebrow, title, subtitle, bullets, image, imageAlt } = Astro.props;
---

<section class="relative min-h-[70vh] overflow-hidden bg-brand-900">
  <Image
    src={image}
    alt={imageAlt}
    class="absolute inset-0 h-full w-full object-cover opacity-60"
    loading="eager"
    fetchpriority="high"
    widths={[640, 1024, 1920]}
    sizes="100vw"
  />
  <div class="absolute inset-0 bg-gradient-to-r from-brand-900/95 via-brand-900/75 to-brand-900/40"></div>

  <div class="relative mx-auto flex max-w-6xl flex-col justify-center px-4 py-20 sm:px-6 lg:min-h-[70vh] lg:px-8">
    <p class="text-sm font-semibold uppercase tracking-widest text-brand-300">{eyebrow}</p>
    <h1 class="text-display mt-4 max-w-2xl text-3xl font-bold text-paper sm:text-4xl lg:text-5xl">
      {title}
    </h1>
    <p class="mt-4 max-w-xl text-lg text-brand-50/90">{subtitle}</p>

    <ul class="mt-8 grid max-w-xl gap-3 sm:grid-cols-2">
      {bullets.map((bullet) => (
        <li class="flex items-start gap-2 text-sm text-paper">
          <Icon name="lucide:check" class="mt-0.5 h-5 w-5 shrink-0 text-accent" aria-hidden="true" />
          <span>{bullet}</span>
        </li>
      ))}
    </ul>

    <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
      <a href="/get-estimate" class="btn btn-primary">Get my free estimate</a>
      <a
        href={`tel:${siteConfig.phone.primaryTel}`}
        class="btn btn-secondary border-paper/40 text-paper hover:bg-paper/10"
      >
        Call {siteConfig.phone.primary}
      </a>
    </div>
  </div>
</section>
