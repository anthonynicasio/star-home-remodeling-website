---
import { Icon } from 'astro-icon/components';
---

<section class="bg-brand-50">
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8">
    <div class="card flex flex-col items-start gap-6 overflow-hidden p-8 md:flex-row md:items-center md:justify-between md:p-10">
      <div class="flex items-start gap-5">
        <span class="hidden h-14 w-14 shrink-0 items-center justify-center rounded-full bg-brand-50 text-brand-700 sm:flex">
          <Icon name="lucide:wallet" class="h-7 w-7" aria-hidden="true" />
        </span>
        <div>
          <h2 class="text-display text-2xl font-bold text-brand-900">Flexible project planning</h2>
          <p class="prose-star mt-2 max-w-xl text-sm">
            Don't put off the exterior upgrades your home needs. Ask about available payment options
            during your free estimate so you can move forward on a timeline that fits your budget.
          </p>
        </div>
      </div>
      <a href="/financing" class="btn btn-primary shrink-0">Ask About Options</a>
    </div>
  </div>
</section>
