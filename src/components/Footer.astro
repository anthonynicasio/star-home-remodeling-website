---
import { siteConfig, getNapString } from '../lib/site-config';
import { services } from '../lib/services';
import Logo from './Logo.astro';
---

<footer class="bg-brand-900 text-brand-50">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
      <div>
        <Logo variant="inverse" showWordmark={true} class="inline-flex" />
        <p class="mt-3 text-sm text-brand-300">
          Family-run contractor serving Fairfax and the greater DMV.
        </p>
        <div class="mt-4 space-y-1 text-sm">
          <p>{getNapString()}</p>
          <p>
            <a href={`tel:${siteConfig.phone.primaryTel}`} class="font-semibold text-paper hover:text-accent">
              {siteConfig.phone.primary}
            </a>
          </p>
        </div>
      </div>

      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-paper">Services</h2>
        <ul class="mt-4 space-y-2 text-sm">
          {services.map((s) => (
            <li>
              <a href={`/services/${s.slug}`} class="text-brand-300 hover:text-paper">
                {s.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-paper">Company</h2>
        <ul class="mt-4 space-y-2 text-sm">
          <li><a href="/about" class="text-brand-300 hover:text-paper">About us</a></li>
          <li><a href="/gallery" class="text-brand-300 hover:text-paper">Project gallery</a></li>
          <li><a href="/reviews" class="text-brand-300 hover:text-paper">Reviews</a></li>
          <li><a href="/service-areas" class="text-brand-300 hover:text-paper">Service areas</a></li>
          <li><a href="/financing" class="text-brand-300 hover:text-paper">Financing</a></li>
          <li><a href="/contact" class="text-brand-300 hover:text-paper">Contact</a></li>
        </ul>
      </div>

      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-paper">Hours</h2>
        <ul class="mt-4 space-y-1 text-sm text-brand-300">
          <li>{siteConfig.hours.weekdays}</li>
          <li>{siteConfig.hours.saturday}</li>
          <li>{siteConfig.hours.sunday}</li>
        </ul>
        {siteConfig.social.facebook && (
          <a
            href={siteConfig.social.facebook}
            class="mt-4 inline-block text-sm text-brand-300 hover:text-paper"
            target="_blank"
            rel="noopener noreferrer"
          >
            Facebook
          </a>
        )}
        {siteConfig.license.number ? (
          <p class="mt-4 text-xs text-brand-300">License: {siteConfig.license.number}</p>
        ) : (
          <p class="mt-4 text-xs text-brand-300/70">License #: // TODO: confirm with client</p>
        )}
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-4 border-t border-brand-700 pt-8 text-xs text-brand-300 sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; {new Date().getFullYear()} {siteConfig.name}. All rights reserved.</p>
      <p>BBB Accredited - Licensed &amp; insured {/* TODO: confirm wording with client */}</p>
    </div>
  </div>
</footer>
