---
import { siteConfig, getNapString } from '../lib/site-config';
import { services } from '../lib/services';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import logo from '../assets/brand/logo.png';

const year = new Date().getFullYear();
const socials = [
  siteConfig.social.facebook && { href: siteConfig.social.facebook, label: 'Facebook', icon: 'lucide:facebook' },
  siteConfig.social.instagram && { href: siteConfig.social.instagram, label: 'Instagram', icon: 'lucide:instagram' },
].filter(Boolean) as { href: string; label: string; icon: string }[];
---

<footer class="bg-brand-900 text-brand-50">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
      <div>
        <a href="/" class="inline-flex" aria-label="Star Home Remodeling home">
          <Image
            src={logo}
            alt="Star Home Remodeling"
            width={176}
            height={176}
            class="h-20 w-20 rounded-[var(--radius-default)] bg-paper object-contain p-2 shadow-[var(--shadow-soft)]"
          />
        </a>
        <p class="mt-4 max-w-xs text-sm text-brand-300">
          A local, family-run home remodeling company helping DMV homeowners improve their roofing,
          siding, windows, and exterior spaces — from estimate to final walkthrough.
        </p>
        {socials.length > 0 && (
          <div class="mt-5 flex gap-3">
            {socials.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={s.label}
                class="flex h-9 w-9 items-center justify-center rounded-full border border-brand-700 text-brand-300 transition-colors hover:border-gold hover:text-gold"
              >
                <Icon name={s.icon} class="h-4 w-4" aria-hidden="true" />
              </a>
            ))}
          </div>
        )}
      </div>

      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-paper">Services</h2>
        <ul class="mt-4 space-y-2.5 text-sm">
          {services.map((s) => (
            <li>
              <a href={`/services/${s.slug}`} class="text-brand-300 hover:text-gold">{s.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-paper">Company</h2>
        <ul class="mt-4 space-y-2.5 text-sm">
          <li><a href="/about" class="text-brand-300 hover:text-gold">About Us</a></li>
          <li><a href="/gallery" class="text-brand-300 hover:text-gold">Project Gallery</a></li>
          <li><a href="/reviews" class="text-brand-300 hover:text-gold">Reviews</a></li>
          <li><a href="/service-areas" class="text-brand-300 hover:text-gold">Service Areas</a></li>
          <li><a href="/financing" class="text-brand-300 hover:text-gold">Project Planning</a></li>
          <li><a href="/contact" class="text-brand-300 hover:text-gold">Contact</a></li>
        </ul>
      </div>

      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-paper">Get in touch</h2>
        <ul class="mt-4 space-y-3 text-sm text-brand-300">
          <li>
            <a href={`tel:${siteConfig.phone.primaryTel}`} class="flex items-center gap-2 font-semibold text-paper hover:text-gold">
              <Icon name="lucide:phone" class="h-4 w-4" aria-hidden="true" />
              {siteConfig.phone.primary}
            </a>
          </li>
          <li class="flex items-center gap-2">
            <Icon name="lucide:mail" class="h-4 w-4" aria-hidden="true" />
            <a href={`mailto:${siteConfig.email}`} class="hover:text-gold">{siteConfig.email}</a>
          </li>
          <li class="flex items-start gap-2">
            <Icon name="lucide:map-pin" class="mt-0.5 h-4 w-4 shrink-0" aria-hidden="true" />
            <span>{getNapString()}</span>
          </li>
          <li class="flex items-start gap-2">
            <Icon name="lucide:clock" class="mt-0.5 h-4 w-4 shrink-0" aria-hidden="true" />
            <span>{siteConfig.hours.weekdays}</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-3 border-t border-brand-700 pt-8 text-xs text-brand-300 sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; {year} {siteConfig.name}. All rights reserved.</p>
      <p class="flex flex-wrap items-center gap-x-4 gap-y-1">
        {siteConfig.licensedAndInsured && (
          <span>Licensed &amp; insured{siteConfig.license.number ? ` · Lic. #${siteConfig.license.number}` : ''}</span>
        )}
        <a href="/privacy" class="hover:text-gold">Privacy Policy</a>
      </p>
    </div>
  </div>
</footer>
