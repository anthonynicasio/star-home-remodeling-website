---
import { siteConfig } from '../lib/site-config';
import { services } from '../lib/services';
import { Icon } from 'astro-icon/components';
import Logo from './Logo.astro';

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/gallery', label: 'Projects' },
  { href: '/reviews', label: 'Reviews' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<div class="sticky top-0 z-50">
  <!-- Utility strip -->
  <div class="hidden bg-brand-900 text-brand-50/90 lg:block">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-2 text-xs sm:px-6 lg:px-8">
      <p class="flex items-center gap-2">
        <Icon name="lucide:map-pin" class="h-3.5 w-3.5 text-gold" aria-hidden="true" />
        Proudly serving Washington, DC · Northern Virginia · Maryland suburbs
      </p>
      <p class="flex items-center gap-4">
        <span class="flex items-center gap-1.5">
          <Icon name="lucide:shield-check" class="h-3.5 w-3.5 text-gold" aria-hidden="true" />
          Licensed &amp; insured
        </span>
        <a href={`tel:${siteConfig.phone.primaryTel}`} class="flex items-center gap-1.5 font-semibold text-paper hover:text-gold">
          <Icon name="lucide:phone" class="h-3.5 w-3.5" aria-hidden="true" />
          {siteConfig.phone.primary}
        </a>
      </p>
    </div>
  </div>

  <header class="border-b border-brand-900/5 bg-canvas/95 backdrop-blur-md">
    <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-2 sm:px-6 lg:py-2.5 lg:px-8">
      <Logo />

      <nav class="hidden items-center gap-1 lg:flex" aria-label="Main">
        <a
          href="/"
          class:list={['rounded-full px-3 py-2 text-sm font-medium transition-colors hover:bg-brand-50', isActive('/') && 'text-brand-700']}
        >
          Home
        </a>

        <div class="group static">
          <a
            href="/services"
            class:list={['flex items-center gap-1 rounded-full px-3 py-2 text-sm font-medium transition-colors hover:bg-brand-50', currentPath.startsWith('/services') && 'text-brand-700']}
            aria-haspopup="true"
          >
            Services
            <Icon name="lucide:chevron-down" class="h-4 w-4 transition-transform group-hover:rotate-180" aria-hidden="true" />
          </a>
          <div
            class="invisible absolute left-1/2 top-full z-50 w-[min(60rem,calc(100vw-2rem))] -translate-x-1/2 px-4 pt-3 opacity-0 transition-all group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100"
            role="menu"
          >
            <div class="rounded-[var(--radius-lg)] border border-brand-900/5 bg-paper p-6 shadow-[var(--shadow-card)]">
              <div class="grid grid-cols-3 gap-x-8 gap-y-6">
                {services.map((s) => (
                  <div role="none">
                    <a
                      href={`/services/${s.slug}`}
                      class="flex items-center gap-2 border-b border-brand-900/5 pb-2 text-sm font-bold text-brand-900 hover:text-brand-700"
                      role="menuitem"
                    >
                      <Icon name={s.icon} class="h-4 w-4 text-accent" aria-hidden="true" />
                      {s.name}
                    </a>
                    <ul class="mt-2.5 space-y-1.5">
                      {s.subServices.map((sub) => (
                        <li>
                          <a
                            href={`/services/${s.slug}`}
                            class="block text-sm text-stone-400 transition-colors hover:text-brand-700"
                            role="menuitem"
                          >
                            {sub}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
              <div class="mt-6 flex items-center justify-between border-t border-brand-900/5 pt-4">
                <a href="/services" class="text-sm font-semibold text-brand-700 hover:text-accent">
                  View all services →
                </a>
                <a href="/get-estimate" class="btn btn-primary text-sm">Get a Free Quote</a>
              </div>
            </div>
          </div>
        </div>

        {navLinks.slice(1).map((link) => (
          <a
            href={link.href}
            class:list={['rounded-full px-3 py-2 text-sm font-medium transition-colors hover:bg-brand-50', isActive(link.href) && 'text-brand-700']}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <div class="hidden items-center gap-3 lg:flex">
        <a href="/get-estimate" class="btn btn-primary text-sm">Get a Free Quote</a>
      </div>

      <!-- Mobile menu -->
      <details class="relative lg:hidden">
        <summary class="btn-ghost flex min-h-11 min-w-11 cursor-pointer list-none items-center justify-center rounded-[var(--radius-default)] p-2 [&::-webkit-details-marker]:hidden">
          <span class="sr-only">Open menu</span>
          <Icon name="lucide:menu" class="h-6 w-6" aria-hidden="true" />
        </summary>
        <nav
          class="absolute right-0 top-full z-50 mt-2 w-72 rounded-[var(--radius-default)] border border-brand-900/10 bg-paper p-4 shadow-[var(--shadow-card)]"
          aria-label="Mobile"
        >
          <a href="/" class="block rounded-lg px-3 py-2 font-medium text-brand-900 hover:bg-brand-50">Home</a>
          <p class="px-3 pb-1 pt-3 text-xs font-semibold uppercase tracking-wide text-stone-400">Services</p>
          {services.map((s) => (
            <details class="group/svc">
              <summary class="flex cursor-pointer list-none items-center justify-between rounded-lg px-3 py-2 text-sm font-medium text-ink hover:bg-brand-50 [&::-webkit-details-marker]:hidden">
                <span class="flex items-center gap-2.5">
                  <Icon name={s.icon} class="h-4 w-4 text-brand-700" aria-hidden="true" />
                  {s.name}
                </span>
                <Icon name="lucide:chevron-down" class="h-4 w-4 text-stone-400 transition-transform group-open/svc:rotate-180" aria-hidden="true" />
              </summary>
              <div class="ml-7 border-l border-brand-900/10 pl-3">
                <a href={`/services/${s.slug}`} class="block rounded-lg px-3 py-1.5 text-sm font-medium text-brand-700 hover:bg-brand-50">
                  All {s.name}
                </a>
                {s.subServices.map((sub) => (
                  <a href={`/services/${s.slug}`} class="block rounded-lg px-3 py-1.5 text-sm text-stone-400 hover:bg-brand-50 hover:text-brand-700">
                    {sub}
                  </a>
                ))}
              </div>
            </details>
          ))}
          <hr class="my-3 border-brand-900/10" />
          {navLinks.slice(1).map((link) => (
            <a href={link.href} class="block rounded-lg px-3 py-2 text-sm hover:bg-brand-50">{link.label}</a>
          ))}
          <hr class="my-3 border-brand-900/10" />
          <a href={`tel:${siteConfig.phone.primaryTel}`} class="flex items-center gap-2 rounded-lg px-3 py-2 font-semibold text-brand-700 hover:bg-brand-50">
            <Icon name="lucide:phone" class="h-4 w-4" aria-hidden="true" />
            {siteConfig.phone.primary}
          </a>
          <a href="/get-estimate" class="btn btn-primary mt-3 w-full">Get a Free Quote</a>
        </nav>
      </details>
    </div>
  </header>
</div>
