---
interface Props {
  count?: number;
  size?: string;
  class?: string;
}

const { count = 5, size = 'h-4 w-4', class: className = '' } = Astro.props;
const star =
  'M12 2l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545L12 17.77l-5.878 3.09 1.123-6.545L2.49 8.91l6.572-.955L12 2z';
---

<span class:list={['inline-flex items-center gap-0.5 text-accent', className]} aria-label={`${count} out of 5 stars`} role="img">
  {Array.from({ length: count }).map(() => (
    <svg viewBox="0 0 24 24" fill="currentColor" class={size} aria-hidden="true">
      <path d={star} />
    </svg>
  ))}
</span>
