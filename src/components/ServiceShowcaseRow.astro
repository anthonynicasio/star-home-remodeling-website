---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  kicker?: string;
  body: string;
  image: ImageMetadata;
  imageAlt: string;
  href: string;
  ctaLabel: string;
  reverse?: boolean;
}

const { title, kicker, body, image, imageAlt, href, ctaLabel, reverse = false } = Astro.props;
---

<div class:list={['grid items-center gap-10 lg:grid-cols-2 lg:gap-16', reverse && 'lg:[&>*:first-child]:order-2']}>
  <div>
    {kicker && <p class="text-sm font-semibold uppercase tracking-wide text-brand-700">{kicker}</p>}
    <h2 class="text-display mt-2 text-2xl font-bold sm:text-3xl">{title}</h2>
    <p class="prose-star mt-4 text-base">{body}</p>
    <a href={href} class="mt-6 inline-flex items-center gap-2 font-semibold text-brand-700 hover:text-accent">
      {ctaLabel}
      <span aria-hidden="true">→</span>
    </a>
  </div>
  <div class="overflow-hidden rounded-[var(--radius-default)] shadow-[var(--shadow-card)]">
    <Image
      src={image}
      alt={imageAlt}
      class="h-full w-full object-cover"
      widths={[400, 600, 800]}
      sizes="(max-width: 1024px) 100vw, 50vw"
      loading="lazy"
    />
  </div>
</div>
