---
import Section from './Section.astro';
---

<Section variant="stone">
  <div class="mx-auto max-w-lg text-center">
    <h2 class="text-display text-xl font-bold">Project tips &amp; seasonal reminders</h2>
    <p class="prose-star mt-2 text-sm">Practical advice for DMV homeowners    no spam.</p>
    <form class="mt-6 flex flex-col gap-3 sm:flex-row" action="#" method="post">
      <label class="sr-only" for="newsletter-email">Email address</label>
      <input
        id="newsletter-email"
        type="email"
        name="email"
        required
        placeholder="you@example.com"
        class="min-h-11 flex-1 rounded-[var(--radius-default)] border border-brand-300/50 px-4 text-ink"
      />
      <button type="submit" class="btn btn-primary shrink-0">Subscribe</button>
    </form>
    <p class="mt-3 text-xs text-stone-400">// TODO: wire to client's existing newsletter provider</p>
  </div>
</Section>
