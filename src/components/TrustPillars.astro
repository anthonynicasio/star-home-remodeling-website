---
import { Icon } from 'astro-icon/components';

interface Pillar {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  title?: string;
  pillars: Pillar[];
}

const { title = 'The Star difference', pillars } = Astro.props;
const gridCols = pillars.length % 3 === 0 ? 'lg:grid-cols-3' : 'lg:grid-cols-4';
---

<div>
  {title && <h2 class="text-display text-center text-2xl font-bold sm:text-3xl">{title}</h2>}
  <div class:list={['grid gap-6 sm:grid-cols-2', gridCols, title && 'mt-12']}>
    {pillars.map((pillar) => (
      <article class="card p-7">
        <div class="flex h-12 w-12 items-center justify-center rounded-full bg-brand-50 text-brand-700">
          <Icon name={pillar.icon} class="h-6 w-6" aria-hidden="true" />
        </div>
        <h3 class="text-display mt-5 text-lg font-semibold">{pillar.title}</h3>
        <p class="prose-star mt-2 text-sm">{pillar.description}</p>
      </article>
    ))}
  </div>
</div>
