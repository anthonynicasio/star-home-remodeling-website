---
import '../styles/global.css';
import Font from 'astro/components/Font.astro';
import { ClientRouter } from 'astro:transitions';
import SEOHead from '../components/seo/SEO.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const { title, description, canonical, ogImage, noindex } = Astro.props;
const ga4Id = import.meta.env.PUBLIC_GA4_ID;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <Font cssVariable="--font-display" preload />
    <Font cssVariable="--font-body" preload />
    <SEOHead
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      noindex={noindex}
    />
    <ClientRouter />
    <slot name="head" />
    {ga4Id && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
        <script is:inline define:vars={{ ga4Id }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() {
            dataLayer.push(arguments);
          }
          gtag('js', new Date());
          gtag('config', ga4Id);
        </script>
      </>
    )}
  </head>
  <body class="flex min-h-screen flex-col">
    <slot name="promo" />
    <slot name="header" />
    <main class="flex-1">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
